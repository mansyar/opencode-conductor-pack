{
  "name": "@ansyar/conductor-plugin",
  "version": "0.1.0",
  "description": "OpenCode Conductor Plugin - Context-Driven Development for AI-assisted coding",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "check": "npm run lint && npm run test:run && npm run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "conductor",
    "cdd",
    "context-driven"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "vite": "^5.0.12"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^0.0.1",
    "@opencode-ai/sdk": "^0.0.1"
  }
}